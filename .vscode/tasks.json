{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "bun: install - frontend",
			"type": "shell",
			"command": "bun install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"problemMatcher": [],
			"detail": "install dependencies with bun"
		},
		{
			"label": "bun: dev - frontend",
			"type": "shell",
			"command": "bun run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"problemMatcher": [],
			"detail": "start Next.js dev server with bun"
		},
		{
			"label": "bun: build - frontend",
			"type": "shell",
			"command": "bun run build",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"problemMatcher": [],
			"detail": "build frontend with bun"
		},
		{
			"label": "bun: start - frontend",
			"type": "shell",
			"command": "bun run start",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"problemMatcher": [],
			"detail": "start production frontend with bun"
		},
		{
			"label": "bun: lint - frontend",
			"type": "shell",
			"command": "bun run lint",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"problemMatcher": [],
			"detail": "lint frontend with bun"
		}
	]
}